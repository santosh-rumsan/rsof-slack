# Dev server port
WEB_PORT=5173

# API proxy target (dev server only)
API_URL=http://localhost:8000

# Work hours window for the user presence timeline (24h format, integers)
VITE_WORK_START_HOUR=7
VITE_WORK_END_HOUR=23

# Google OAuth client ID for the login button
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Base URL of the rs-office authentication API (no trailing slash)
VITE_AUTH_API_BASE_URL=https://rsoffice-users-api.rumsan.xyz

# App ID registered in the rs-office identity platform.
# Sent as X-App-Id header during token exchange.
VITE_APP_ID=your-app-id-here
