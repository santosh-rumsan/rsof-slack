# ── Slack ────────────────────────────────────────────────────────────────────
# Bot token — starts with xoxb-
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Used by the app (Prisma). docker-compose overrides this automatically.
DATABASE_URL=postgresql://rsof:rsof_password@localhost:5432/rsof_slack

# Postgres password (used by docker-compose to create the postgres service)
POSTGRES_PASSWORD=rsof_password

# ── Auth ──────────────────────────────────────────────────────────────────────
# API key that protects all /api/v1/admin/* endpoints and the web UI
API_KEY=change-me-to-a-strong-random-string

# App ID used for JWT role verification. Roles in the token look like {APP_ID}|admin.
# Must match the app_id issued by your identity provider (rs-office users API).
APP_ID=your-app-id-here

# RS256 public key PEM for verifying JWTs on /api/v1/admin/* and /api/v1/me/* endpoints.
# Paste your identity provider's public key here (newlines as \n).
# Leave empty to disable JWT auth (API key only will work).
JWT_PUBLIC_KEY_PEM=

# ── User management system ────────────────────────────────────────────────────
# URL that returns a flat JSON array of { user_cuid, external_id, user_timezone, ... } objects
USER_MGMT_API_URL=https://rsoffice-users-api.rumsan.xyz/users/external/slack

# Bearer token sent to the user management API
USER_MGMT_API_KEY=your-user-mgmt-api-key

# ── Scheduler intervals (minutes) ────────────────────────────────────────────
# These are seeded into the DB on first run. Change them via the admin settings UI at runtime.
USER_SYNC_INTERVAL=30
PRESENCE_RECONCILE_INTERVAL=5
USER_MAPPING_SYNC_INTERVAL=60

# ── Timezone & work hours ─────────────────────────────────────────────────────
# Timezone used for report calculations (IANA timezone name)
TIMEZONE=Asia/Kathmandu

# ── App ───────────────────────────────────────────────────────────────────────
APP_PORT=8000
LOG_LEVEL=info
